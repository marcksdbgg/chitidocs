GEMINI_API_KEY="tu_api_key_de_gemini" # Solo backend (Vercel Functions)

# Configuración de Cloudflare R2 (S3)
# Estas variables se usan en el backend (Vercel Functions)
R2_ACCOUNT_ID="tu_account_id"
R2_ACCESS_KEY_ID="tu_access_key"
R2_SECRET_ACCESS_KEY="tu_secret_key"
R2_BUCKET_NAME="nombre_del_bucket"
R2_PUBLIC_URL="https://pub-xxxxxx.r2.dev"

# Credenciales de Firebase Admin para validar sesión en APIs backend
FIREBASE_PROJECT_ID="tu_firebase_project_id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
