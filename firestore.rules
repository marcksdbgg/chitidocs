rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        hasRole('superadmin') || 
        (request.auth.token.email == 'mark.romero.dev@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function isDirector() {
      return isSuperAdmin() || hasRole('director');
    }

    function isAdminOrDirector() {
      return isSuperAdmin() || hasRole('director') || hasRole('subdirector');
    }

    function isMesaPartes() {
      return isDirector() || hasRole('subdirector') || hasRole('mesa_partes') || hasRole('secretaria');
    }

    function isDocente() {
      return hasRole('docente') || hasRole('jefe_area');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userInstitution() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? getUserData().institutionId
        : null;
    }

    function sameInstitution(existingInstitutionId) {
      return userInstitution() == null || existingInstitutionId == null || existingInstitutionId == userInstitution();
    }

    function hasRequiredTramiteFields() {
      return request.resource.data.numero is string &&
             request.resource.data.asunto is string &&
             request.resource.data.solicitanteNombre is string &&
             request.resource.data.estado is string &&
             request.resource.data.createdAt != null &&
             request.resource.data.updatedAt != null;
    }

    function hasRequiredDocumentFields() {
      return request.resource.data.fileName is string &&
             request.resource.data.fileUrl is string &&
             request.resource.data.fileType is string &&
             request.resource.data.uploadedById == request.auth.uid &&
             request.resource.data.createdAt != null;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && (
        request.resource.data.role == 'docente' || 
        (request.auth.token.email == 'mark.romero.dev@gmail.com' && request.resource.data.role == 'director') ||
        isSuperAdmin()
      );
      allow update: if (isDirector() && sameInstitution(resource.data.institutionId)) ||
                    (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /documents/{docId} {
      allow read: if isAuthenticated() && sameInstitution(resource.data.institucionId);
      allow create: if isMesaPartes() && hasRequiredDocumentFields() && sameInstitution(request.resource.data.institucionId);
      allow update: if (isMesaPartes() || (isAuthenticated() && resource.data.uploadedById == request.auth.uid)) &&
                    sameInstitution(resource.data.institucionId) &&
                    sameInstitution(request.resource.data.institucionId);
      allow delete: if isDirector() || (isAuthenticated() && resource.data.uploadedById == request.auth.uid && sameInstitution(resource.data.institucionId));
    }

    match /tramites/{tramiteId} {
      allow read: if isAuthenticated() && sameInstitution(resource.data.institucionId);
      allow create: if isMesaPartes() && hasRequiredTramiteFields() && sameInstitution(request.resource.data.institucionId);
      allow update: if (
        isMesaPartes() ||
        (isDocente() && (
          resource.data.asignadoAId == request.auth.uid ||
          request.resource.data.asignadoAId == request.auth.uid
        ))
      ) &&
      sameInstitution(resource.data.institucionId) &&
      sameInstitution(request.resource.data.institucionId);
      allow delete: if isDirector() && sameInstitution(resource.data.institucionId);
    }

    match /audit_logs/{logId} {
      allow read: if isAdminOrDirector();
      allow create: if isAuthenticated() &&
                    request.resource.data.actorId == request.auth.uid &&
                    request.resource.data.type is string &&
                    request.resource.data.createdAt != null;
      allow update, delete: if false;
    }
  }
}
